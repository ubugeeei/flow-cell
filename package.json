{
  "name": "flowcell",
  "version": "0.1.0",
  "description": "Experimental Flow typed React state graph built around cells and derived values.",
  "packageManager": "yarn@1.22.22",
  "main": "./Flowcell.js",
  "module": "./Flowcell.mjs",
  "exports": {
    ".": {
      "import": "./Flowcell.mjs",
      "require": "./Flowcell.js",
      "default": "./Flowcell.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "Flowcell.js",
    "Flowcell.mjs",
    "Flowcell.js.flow",
    "README.md"
  ],
  "scripts": {
    "build": "node Build.js",
    "flow": "flow check",
    "prepare": "node Build.js",
    "smoke": "node Smoke.js",
    "test": "jest --config Jest.config.cjs",
    "verify": "yarn flow && yarn test && yarn build && yarn smoke"
  },
  "keywords": [
    "flow",
    "react",
    "state",
    "suspense"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubugeeei/flowcell.git"
  },
  "bugs": {
    "url": "https://github.com/ubugeeei/flowcell/issues"
  },
  "homepage": "https://github.com/ubugeeei/flowcell#readme",
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.9",
    "@babel/plugin-transform-modules-commonjs": "^7.24.8",
    "@babel/preset-flow": "^7.24.7",
    "babel-jest": "^29.7.0",
    "flow-bin": "^0.239.0",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-test-renderer": "^18.3.1"
  }
}
